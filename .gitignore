# Local-only: Claude Code session transcripts and personal resume drafts
archive/sessions/
docs/resume/
# Loose session logs dropped at repo root (date-prefixed .txt)
20*-*.txt
# Python venv used by tools/eval/fetch_cmteb.py (one-shot HF fixture loader)
tools/eval/.venv/

# Rendered deployment files — scripts/install.sh substitutes APP_DIR /
# APP_USER / SERVER_NAME at install time; the rendered output bakes in
# absolute server paths + chosen domain and must not be committed.
infra/systemd/*.rendered.service
infra/nginx/*.rendered.conf

# Prometheus basic-auth web config — contains a real bcrypt hash of
# the operator's password. Only the .example template is committed;
# the actual web.yml is generated server-side via htpasswd and stays
# on disk only.
infra/cloud/prometheus-web.yml

# Vite build output baked into the fat jar by mvn package. File names
# are hash-suffixed (index-<hash>.js / index-<hash>.css) so committing
# them causes diverging-history conflicts whenever local and remote
# happen to build separately. deploy.sh always re-runs `npm run build`
# before `mvn package`, so the bundle is reproduced on every deploy.
src/main/resources/static/
docs/2026-05-05-deploy-cheatsheet.md
